{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bitaxe Vendor",
  "type": "object",
  "required": [
    "name",
    "slug",
    "website",
    "region",
    "country",
    "active"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 80,
      "description": "Public display name of the vendor"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "URL-safe identifier, must match filename \u2014 lowercase letters, numbers, and hyphens only (e.g. \"pivotal-mining\")"
    },
    "website": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://",
      "description": "Full HTTPS URL of the vendor's website"
    },
    "region": {
      "type": "string",
      "enum": [
        "Europe",
        "North America",
        "South America",
        "Asia Pacific",
        "Middle East",
        "Africa",
        "India"
      ],
      "description": "Geographic region for filtering on the Bitaxe website"
    },
    "country": {
      "type": "string",
      "minLength": 2,
      "maxLength": 60,
      "description": "Country name (full name preferred, e.g. 'Italy', 'Germany', 'Australia'; common abbreviations like 'USA' are also accepted)"
    },
    "description": {
      "type": "string",
      "maxLength": 280,
      "description": "Optional short description (max 280 chars)"
    },
    "active": {
      "type": "boolean",
      "description": "Set to false to hide the vendor without deleting the file"
    },
    "social": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "x": {
          "description": "Full HTTPS URL to X (Twitter) profile, or empty string to omit",
          "oneOf": [
            {
              "type": "string",
              "format": "uri",
              "pattern": "^https://"
            },
            {
              "type": "string",
              "maxLength": 0
            }
          ]
        },
        "instagram": {
          "description": "Full HTTPS URL to Instagram profile, or empty string to omit",
          "oneOf": [
            {
              "type": "string",
              "format": "uri",
              "pattern": "^https://"
            },
            {
              "type": "string",
              "maxLength": 0
            }
          ]
        },
        "youtube": {
          "description": "Full HTTPS URL to YouTube channel, or empty string to omit",
          "oneOf": [
            {
              "type": "string",
              "format": "uri",
              "pattern": "^https://"
            },
            {
              "type": "string",
              "maxLength": 0
            }
          ]
        },
        "tiktok": {
          "description": "Full HTTPS URL to TikTok profile, or empty string to omit",
          "oneOf": [
            {
              "type": "string",
              "format": "uri",
              "pattern": "^https://"
            },
            {
              "type": "string",
              "maxLength": 0
            }
          ]
        },
        "nostr": {
          "description": "Full HTTPS URL to Nostr profile page, or empty string to omit",
          "oneOf": [
            {
              "type": "string",
              "format": "uri",
              "pattern": "^https://"
            },
            {
              "type": "string",
              "maxLength": 0
            }
          ]
        }
      }
    }
  }
}
